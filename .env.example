PORT=3000
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=1d
MAX_RESERVATIONS_PER_USER_PER_DAY=5

# Estoque diario por refeicao (numero maximo de marmitas por dia).
DEFAULT_DAILY_STOCK_ALMOCO=50
DEFAULT_DAILY_STOCK_JANTAR=50

# (Opcional) Variavel legada — vira o padrao para qualquer refeicao se as duas
# acima nao estiverem definidas. Remova se ja preencheu DEFAULT_DAILY_STOCK_ALMOCO/JANTAR.
# DEFAULT_DAILY_STOCK=50

# Horario de corte por refeicao (hora do dia, 0-23).
# Reservas e cancelamentos do dia atual precisam acontecer antes desses horarios.
CUTOFF_HOUR_ALMOCO=10
CUTOFF_HOUR_JANTAR=18

# (Opcional) Variavel legada — vira o padrao para qualquer refeicao se as duas
# acima nao estiverem definidas. Remova se ja preencheu CUTOFF_HOUR_ALMOCO/JANTAR.
# CUTOFF_HOUR=10

# Tempo de vida do token de recuperacao de senha (em milissegundos).
# Padrao: 1800000 (30 minutos). Em testes automatizados, considere reduzir
# para 500 para validar expiracao rapidamente.
RECOVERY_TOKEN_TTL_MS=1800000
