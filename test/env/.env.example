# Modelo de variáveis usadas pela suíte de testes de API.
# Copie este arquivo para .env.dev / .env.hml / .env.prod e preencha.
# A variável TEST_ENV (definida pelos scripts npm) seleciona qual arquivo carregar.

# URL onde a API da Cantina está rodando.
BASE_URL=http://localhost:3000

# Identificação humana do ambiente (aparece em logs e relatórios).
ENV_NAME=dev

# Credenciais dos usuários do seed (admin e cliente).
ADMIN_EMAIL=admin@cantina.com
ADMIN_PASSWORD=Admin@123
CLIENT_EMAIL=cliente@cantina.com
CLIENT_PASSWORD=Cliente@123

# Quando false, os testes marcados com @destructive são pulados (recomendado em prod).
ALLOW_DESTRUCTIVE=true
